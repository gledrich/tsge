{
  "name": "dino-ge-playground",
  "version": "1.10.8",
  "description": "Interactive, live-editing playground and inspector for Dino GE",
  "bin": {
    "dino-ge-playground": "server.js"
  },
  "type": "module",
  "scripts": {
    "start": "ENVIRONMENT=prod node server.js",
    "dev": "ENVIRONMENT=dev concurrently \"nodemon server.js\" \"vite\"",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "files": [
    "server.js",
    "dist/",
    "scripts/",
    "assets/"
  ],
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "dino-ge": "^1.10.8",
    "express": "^4.21.2",
    "monaco-editor": "^0.55.1",
    "prettier": "^3.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^4.9.0"
  },
  "devDependencies": {
    "@types/prettier": "^2.7.3",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.9",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  },
  "author": "Rich <richgled25@gmail.com>",
