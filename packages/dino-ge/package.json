{
  "name": "dino-ge",
  "version": "1.11.9",
  "description": "Lightweight, performant 2D game engine built with TypeScript",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "docs": "typedoc --exclude '**/*.test.ts' --out ../../docs/api src/ --entryPointStrategy expand"
